{%- liquid
  assign text_alignment = section.settings.text_alignment
  assign container_width = section.settings.container_width
  assign max_width = section.settings.max_width
  assign grid_gutter = section.settings.grid_gutter
  assign form_embed = section.settings.form_embed
  assign color_scheme = section.settings.color_scheme
-%}

{% render 'renderer__color-scheme', name: "section", color_scheme: color_scheme, selector: ".shopify-section", section_id: "password-page" %}

{%- if max_width != 0 and container_width == "" -%}
  {%- capture max_width_style -%}
    style="max-width: {{ max_width }}rem;" 
  {%- endcapture -%}
{%- endif -%}

{% capture spacer %}
  --top-spacing-mobile: {{ section.settings.top_spacing_mobile | default: 100}}px;
  --bottom-spacing-mobile: {{ section.settings.bottom_spacing_mobile | default: 100 }}px;
  --top-spacing-desktop: {{ section.settings.top_spacing_desktop | default: 100 }}px;
  --bottom-spacing-desktop: {{ section.settings.bottom_spacing_desktop | default: 100 }}px;
{% endcapture %}

<section class="mfr-core__password-page" id="password-page" 
  x-data="{ 
    modalOpen: false,

    init() {
      this.closeModalEsc()
    },

    openModal() {
      this.modalOpen = true
    },

    closeModal() {
      this.modalOpen = false
    },

    closeModalEsc() {
      document.addEventListener('keyup', (event) => {
        if (event.key === 'Escape' && this.modalOpen) {
          this.modalOpen = false
        }
      })
    }
  }"
>
  <div class="section-spacer background {{ grid_gutter }}" style="{{ spacer }}">
    <div class="grid-container {{ container_width }}" {{ max_width_style }}>
      <div class="grid-x align-center {{ text_alignment }}">
        <div class="cell small-11 large-12 section-content" data-stagger-inview=".section-icon__wrapper, .section-content__small-text, .section-content__text, .section-content__button">
          {%- content_for "block", type: "_section-content", id: "section-content" -%}
          {% content_for "blocks" %}

          {% if form_embed != blank %}
            <div class="section-form">
              {{ form_embed }}
            </div>
          {% endif %}

          <div class="socials">
            {% render "component__social-links" %}
          </div>
        </div>
      </div>
    </div>

    <button 
      type="button" 
      role="button" 
      class="modal-trigger" 
      aria-label="Enter admin password" 
      @click="openModal()" 
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-shield-lock-fill" viewBox="0 0 16 16">
        <path fill-rule="evenodd" d="M8 0c-.69 0-1.843.265-2.928.56-1.11.3-2.229.655-2.887.87a1.54 1.54 0 0 0-1.044 1.262c-.596 4.477.787 7.795 2.465 9.99a11.8 11.8 0 0 0 2.517 2.453c.386.273.744.482 1.048.625.28.132.581.24.829.24s.548-.108.829-.24a7 7 0 0 0 1.048-.625 11.8 11.8 0 0 0 2.517-2.453c1.678-2.195 3.061-5.513 2.465-9.99a1.54 1.54 0 0 0-1.044-1.263 63 63 0 0 0-2.887-.87C9.843.266 8.69 0 8 0m0 5a1.5 1.5 0 0 1 .5 2.915l.385 1.99a.5.5 0 0 1-.491.595h-.788a.5.5 0 0 1-.49-.595l.384-1.99A1.5 1.5 0 0 1 8 5"/>
      </svg>
    </button>
  </div>

  <template x-teleport="body">
    <div class="mfr-core__password-page-modal-overlay" x-show="modalOpen" x-trap.inert.noscroll="modalOpen" x-transition>
      <div class="mfr-core__password-page-modal" @click.outside="closeModal()">
        <div class="modal-header">
          <h3 class="xlarge no-margin">Storefront Password</h3>
          <button type="button" role="button" aria-label="Close modal" @click="closeModal()"></button>
        </div>
        <div class="modal-body">
          {% form 'storefront_password' %}
            {{ form.errors | default_errors }}
            <div class="form-field" x-data='{ showPassword: false }'>
              <label for="Password" class="ada-hide-element">Enter store password</label>
              <input type="password" name="password" id="Password" placeholder="Enter password" required :type="showPassword ? 'text' : 'password'" >

              <button type="button" role="button" class="password-visibility" aria-label="Toggle password visibility" @click="showPassword = !showPassword">
                <template x-if="showPassword">
                  <div>{%- render 'icon__eyes', icon_type: 'open' -%}</div>
                </template>
                <template x-if="!showPassword">
                  <div>{%- render 'icon__eyes', icon_type: 'close' -%}</div>
                </template>
              </button>
            </div>

            <input type="submit" role="button" class="button secondary" value="Login" />
          {% endform %}
        </div>
      </div>
    </div>
  </template>

  {%- render 'component__gradient-bg-styles' -%}
  {%- render 'component__section-dividers', is_video_background: true -%}
  {% content_for "block", type: "_accent-graphics", id: "accent-graphics" %}
</section>

{% schema %}
  {
    "name": "Password Section",
    "enabled_on": {
      "templates": [
        "password"
      ]
    },
    "settings": [
      {
        "type": "header",
        "content": "Section Settings"
      },
      {
        "type": "html",
        "id": "form_embed",
        "label": "Form Embed"
      },
      {
        "type": "select",
        "id": "text_alignment",
        "options": [
          {
            "value": "",
            "label": "Left"
          },
          {
            "value": "text-center",
            "label": "Center"
          }
        ],
        "label": "Text Alignment",
        "default": "text-center"
      },
      {
        "type": "select",
        "id": "container_width",
        "options": [
          {
            "value": "full",
            "label": "Full"
          },
          {
            "value": "",
            "label": "Contain"
          }
        ],
        "label": "Width",
        "default": "full"
      },
      {
        "type": "range",
        "id": "max_width",
        "min": 0,
        "max": 100,
        "step": 1,
        "unit": "rem",
        "label": "Max Content Width",
        "default": 0
      },
      {
        "type": "select",
        "id": "grid_gutter",
        "options": [
          {
            "value": "grid-gutter",
            "label": "Padding"
          },
          {
            "value": "",
            "label": "No Padding"
          }
        ],
        "label": "Section Padding",
        "default": ""
      },
      {
        "type": "header",
        "content": "Color Schemes"
      },
      {
        "type": "color_scheme",
        "id": "color_scheme",
        "default": "scheme_1",
        "label": "Color Scheme",
        "info": "This will be the color scheme of the header initially."
      },
      {
        "type": "header",
        "content": "Mobile Section Spacing"
      },
      {
        "type": "range",
        "id": "top_spacing_mobile",
        "min": 0,
        "max": 500,
        "step": 10,
        "unit": "px",
        "label": "Top Spacing",
        "default": 100
      },
      {
        "type": "range",
        "id": "bottom_spacing_mobile",
        "min": 0,
        "max": 500,
        "step": 10,
        "unit": "px",
        "label": "Bottom Spacing",
        "default": 100
      },
      {
        "type": "header",
        "content": "Desktop Section Spacing"
      },
      {
        "type": "range",
        "id": "top_spacing_desktop",
        "min": 0,
        "max": 500,
        "step": 10,
        "unit": "px",
        "label": "Top Spacing",
        "default": 100
      },
      {
        "type": "range",
        "id": "bottom_spacing_desktop",
        "min": 0,
        "max": 500,
        "step": 10,
        "unit": "px",
        "label": "Bottom Spacing",
        "default": 100
      }
    ],
    "blocks": [
      {
        "type": "_section-content"
      }
    ],
    "presets": [
      {
        "name":"Password Section",
        "blocks": [
          {
            "type": "_section-content",
            "id": "section-content",
            "static": true,
            "blocks": [
              { "type": "_section-content__icon" },
              { "type": "_section-content__small-text" },
              { "type": "_section-content__title" },
              { "type": "_section-content__text" },
              { "type": "_section-content__button" }
            ]
          }
        ]
      }
    ]
  }
{% endschema %}