{%- comment -%}
--------------------------------------
assign section settings to variables
--------------------------------------
{%- endcomment -%}

{% render 'style-tags__section', asset_file_name: "mfr-core__stacked-cards.css" %}
{%- assign container_width = section.settings.container_width -%}
{%- assign max_width = section.settings.max_width -%}
{%- assign grid_gutter = section.settings.grid_gutter -%}
{%- assign color_theme = section.settings.color_theme -%}
{%- assign custom_class = section.settings.custom_class -%}
{%- assign selected_variant = product.selected_variant -%}
{%- assign content = section.settings.content -%}

{%- assign layout = section.settings.layout -%}
{%- assign desktop_position = section.settings.desktop_content_position -%}
{%- assign mobile_position = section.settings.mobile_content_position -%}

{%- assign section_id = section.settings.custom_id | default: section.id -%}
{% render 'renderer__color-scheme', name: "section", color_scheme: section.settings.color_scheme, section_background: section.settings.custom_bg_color, selector: ".shopify-section", section_id: section_id %}

{%- if max_width != 0 and container_width == "" -%}
  {%- capture max_width_style -%}
    style="max-width: {{ max_width }}rem;"
  {%- endcapture -%}
{%- endif -%}

{% capture spacer %}
  --top-spacing-mobile: {{ section.settings.top_spacing_mobile | default: 100}}px;
  --bottom-spacing-mobile: {{ section.settings.bottom_spacing_mobile | default: 100 }}px;
  --top-spacing-desktop: {{ section.settings.top_spacing_desktop | default: 100 }}px;
  --bottom-spacing-desktop: {{ section.settings.bottom_spacing_desktop | default: 100 }}px;
{% endcapture %}

{% render 'section__settings-styles' %}

<section class="mfr-core__stacked-cards {{ custom_class }} {{ content }}" id="{{ section_id }}">
  <div class="section-spacer background {{ grid_gutter }}" style="{{ spacer }}">
    <div class="grid-container {{ container_width }}" {{ max_width_style }}>
      <div class="grid-x alignment-helper {{ color_theme }} {{ mobile_position }} {{ desktop_position }}">
        <div class="cell small-12 {% if layout != "layout_2" %} large-12 {% else %} large-6 card-content {% endif %} section-content"
          {% if layout == "layout_3" %}
            style="order: 1"
          {% endif %}
          data-stagger-inview=".section-icon__wrapper, .section-content__small-text, .section-content__text, .section-content__button">
          {%- content_for "block", type: "_section-content", id: "section-content" -%}

        {% if layout != "layout_2" %}
          </div>
        {% endif %}

        {% if layout != "layout_2" %}
          <div class="cell small-12 {% if layout == "layout_4" %} large-12 {% else %} large-6 {% endif %} card-content" {% if layout == "layout_3" %}style="order: 3"{% endif %}>
        {% endif %}
          {%- content_for "block", type: "_stacked-cards", id: "stacked-cards" -%}
        </div>

        {% if layout != "layout_4" %}
          <div class="cell small-12 large-6 section-content media-content"
            {% if layout == "layout_3" %}style="order: 2"{% endif %}
            data-mfr-sticky-container=".section-sticky">

            <div class="section-sticky">
              {% if selected_variant != blank %}
                {% assign product_metafield = product.metafields.mfr_fields %}
                {% assign variant_metafield = selected_variant.metafields.mfr_fields %}
                {% assign product_intruction_media = product_metafield.section_instructions.value.media %}
                {% assign product_selling_point_media = product_metafield.section_selling_points.value.media %}
                {% assign intruction_media = variant_metafield.section_instructions.value.media |  default: product_intruction_media %}
                {% assign selling_point_media = variant_metafield.section_selling_points.value.media |  default: product_selling_point_media %}

                {% if content == 'instructions' %}
                  {%  render 'component__media', media: intruction_media, id: section_id %}
                {% elsif content == 'selling_point' %}
                  {%  render 'component__media', media: selling_point_media, id: section_id %}
                {% endif %}

              {% else  %}
                {% content_for "blocks" %}
              {% endif %}
            </div>
          </div>
        {% endif %}
      </div>
    </div>

  {%- render 'component__gradient-bg-styles' -%}
  </div>
  {%- render 'component__section-dividers', is_video_background: true -%}
  {% content_for "block", type: "_accent-graphics", id: "accent-graphics" %}
</section>


{% schema %}
{
  "name": "Stacking Cards",
  "disabled_on": {
    "groups": [
      "header",
      "footer",
      "custom.offcanvas",
      "custom.modals",
      "custom.popups"
    ]
  },
  "settings": [
    {
      "type": "select",
      "id": "content",
      "options": [
        {
          "value": "selling_point",
          "label": "Selling Points"
        },
        {
          "value": "instructions",
          "label": "Instructions"
        }
      ],
      "label": "Content"
    },
    {
      "type": "header",
      "content": "Layout Settings"
    },
    {
      "type": "select",
      "id": "layout",
      "options": [
        {
          "value": "layout_1",
          "label": "Layout 1"
        },
        {
          "value": "layout_2",
          "label": "Layout 2"
        },
        {
          "value": "layout_3",
          "label": "Layout 3"
        },
        {
          "value": "layout_4",
          "label": "Layout 4"
        }
      ],
      "label": "Layout",
      "default": "layout_1"
    },
    {
      "type": "select",
      "id": "desktop_content_position",
      "options": [
        {
          "value": "left-content-position",
          "label": "Left"
        },
        {
          "value": "right-content-position",
          "label": "Right"
        }
      ],
      "label": "Desktop: Content Position",
      "default": "left-content-position"
    },
    {
      "type": "select",
      "id": "mobile_content_position",
      "options": [
        {
          "value": "top-content-position",
          "label": "Top"
        },
        {
          "value": "bottom-content-position",
          "label": "Bottom"
        }
      ],
      "label": "Mobile: Content Position",
      "default": "top-content-position"
    },
    {
      "type": "header",
      "content": "Section Settings"
    },
    {
      "type": "select",
      "id": "container_width",
      "options": [
        {
          "value": "full",
          "label": "Full"
        },
        {
          "value": "",
          "label": "Contain"
        }
      ],
      "label": "Width",
      "default": "full"
    },
    {
      "type": "range",
      "id": "max_width",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "rem",
      "label": "Max Content Width",
      "default": 0
    },
    {
      "type": "select",
      "id": "grid_gutter",
      "options": [
        {
          "value": "",
          "label": "No Margin"
        },
        {
          "value": "grid-gutter-mobile",
          "label": "On Mobile"
        },
        {
          "value": "grid-gutter-desktop",
          "label": "On Desktop"
        },
        {
          "value": "grid-gutter-mobile grid-gutter-desktop",
          "label": "On Both"
        },
      ],
      "label": "Section Margin",
    },
    {
      "type": "header",
      "content": "Alignment Settings"
    },
    {
      "type": "select",
      "id": "mobile_alignment",
      "label": "Content Alignment - Mobile",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "desktop_alignment",
      "label": "Content Alignment - Desktop",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Color Schemes Settings"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "default": "scheme_1",
      "label": "Color Scheme",
      "info": "This will be the color scheme of the header initially."
    },
    {
      "type": "header",
      "content": "Mobile Section Spacing"
    },
    {
      "type": "number",
      "id": "top_spacing_mobile",
      "label": "Top Spacing",
      "default": 100,
      "info": "in pixels. This will use 100px as default value if left empty"
    },
    {
      "type": "number",
      "id": "bottom_spacing_mobile",
      "label": "Bottom Spacing",
      "default": 100,
      "info": "in pixels. This will use 100px as default value if left empty"
    },
    {
      "type": "header",
      "content": "Desktop Section Spacing"
    },
    {
      "type": "number",
      "id": "top_spacing_desktop",
      "label": "Top Spacing",
      "default": 100,
      "info": "in pixels. This will use 100px as default value if left empty"
    },
    {
      "type": "number",
      "id": "bottom_spacing_desktop",
      "label": "Bottom Spacing",
      "default": 100,
      "info": "in pixels. This will use 100px as default value if left empty"
    },
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "color",
      "id": "custom_bg_color",
      "label": "Background Color",
      "info": "For dynamic background color"
    },
    {
      "type": "color_background",
      "id": "bg_color",
      "label": "Background Color/Gradient"
    },
    {
      "type": "image_picker",
      "id": "bg_image_mobile",
      "label": "Background Image - Mobile"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background Image - Desktop"
    },
    {
      "type": "header",
      "content": "Divider Settings"
    },
    {
      "type": "select",
      "id": "section_divider_top",
      "label": "Section Divider - Top",
      "options": [
        {
          "value": "",
          "label": "None"
        },
        {
          "value": "divider_1",
          "label": "Custom Divider 1"
        },
        {
          "value": "line",
          "label": "Line"
        },
        {
          "value": "rounded",
          "label": "Rounded"
        },
        {
          "value": "scale",
          "label": "Scale"
        }
      ],
      "default": ""
    },
    {
      "type": "select",
      "id": "section_divider_bottom",
      "label": "Section Divider - Bottom",
      "options": [
        {
          "value": "",
          "label": "None"
        },
        {
          "value": "divider_1",
          "label": "Custom Divider 1"
        },
        {
          "value": "line",
          "label": "Line"
        },
        {
          "value": "rounded",
          "label": "Rounded"
        }
      ],
      "default": ""
    },
    {
      "type": "header",
      "content": "Attribute Settings"
    },
    {
      "type": "text",
      "id": "custom_class",
      "label": "Custom class"
    },
    {
      "type": "text",
      "id": "custom_id",
      "label": "Custom ID"
    }
  ],
  "blocks": [
    {
      "type": "_section-content"
    },
    {
      "type": "_image"
    },
    {
      "type": "_video-with-controls"
    }
  ],
  "presets": [
    {
      "name": "Stacking Cards",
      "blocks": [
        {
          "type": "_section-content",
          "id": "section-content",
          "static": true,
          "blocks": [
            { "type": "_section-content__title" }
          ]
        },
        {
          "type": "_stacked-cards",
          "id": "stacked-cards",
          "static": true,
          "blocks": [
            { "type": "_stacked-card" }
          ]
        }
      ]
    }
  ]
}
{% endschema %}