{% comment %} {% render 'style-tags__section', asset_file_name: "footer.css", lazyload: true %} {% endcomment %}
{% render 'renderer__color-scheme', name: "footer", color_scheme: section.settings.color_scheme, selector: ".footer" %}
{% assign appear_on = section.settings.appear_on | newline_to_br | strip_newlines | split: '<br />' %}

{% assign embed_items = section.blocks | where: "type", "embed" %}
{% assign menus = section.blocks | where: "type", "menu" %}
{% assign big_menus = section.blocks | where: "type", "big_menu" %}
{% assign socket = section.blocks | where: "type", "socket" | first %}
{% assign social_links = section.blocks | where: "type", "social_links" | first %}

{% if embed_items.size == 0 or template == 'index' %}
  {% assign class = "no-embed" %}
{% endif %}

{% if appear_on == blank or appear_on contains template %}
  <style>
    #footer {
      --footer-overlay-mobile: url('{{ 'footer__overlay-mobile.png' | asset_img_url: 'master' }}');
      --footer-overlay-desktop: url('{{ 'footer__overlay-desktop.png' | asset_img_url: 'master' }}');
    }
  </style>
  <div class="grid-container full grid-x" data-inview>
    <div class="cell small-12 footer__contents">
      {% for embed in embed_items %}
        {% if embed != blank and template != 'index' and request.host contains embed.settings.domain %}
          <div class="footer__embed"
            data-stagger-inview=".footer__embed-icon,.footer__embed-heading,.footer__embed-caption,.footer__embed-code, .footer__copyright">
            <div class="footer__embed-left">
              {% if embed.settings.image != blank %}
                {% assign alt = embed.settings.image.alt |  default: "embed image" %}

                <div class="footer__embed-icon">
                  {% render 'component__lazyload-image',
                      image: embed.settings.image,
                      alt: alt,
                      width: 300 | plus: 100 %}
                </div>
              {% endif %}
              {% if embed.settings.heading != blank %}
                <p class="footer__embed-heading regular">
                  {{ embed.settings.heading }}
                </p>
              {% endif %}

              {% if embed.settings.caption != blank %}
                <p class="footer__embed-caption">
                  {{ embed.settings.caption }}
                </p>
              {% endif %}
            </div>
            <div class="footer__embed-right">
              {% if embed.settings.description != blank %}
                <div class="footer__embed-desc">
                  {{ embed.settings.description }}
                </div>
              {% endif %}

              {% if embed.settings.embed_code != blank %}
                <div class="footer__embed-code">
                  {{ embed.settings.embed_code | newline_to_br }}
                </div>
              {% endif %}
            </div>

            <div class="section-divider__top">
              {% render 'assets__top-divider-1', color: "#ef3373" %}
            </div>
            <div class="section-divider__left">
              {% render 'assets__left-divider', color: "#ef3373" %}
            </div>
          </div>
        {% endif %}
      {% endfor %}


      {% if big_menus != blank %}
        <div class="footer__big-menus">
          {% for big_menu in big_menus %}
            <div class="footer__big-menu">
              <p class="footer__big-menu-label">
                {{ big_menu.settings.label }}
              </p>
              <ul class="footer__big-menu-list" data-stagger-inview="li">
                {% for link in big_menu.settings.menu.links %}
                  <li>
                    <a href="{{ link.url }}"
                      class="h5"
                      aria-label="{{ link.title }}"
                      title="{{ link.title }}">
                      <span>{{ link.title }}</span>
                    </a>
                  </li>
                {% endfor %}
              </ul>
            </div>
          {% endfor %}
        </div>
      {% endif %}

      {% if menus != blank %}
        <div class="footer__content {{ class }}">
          {% comment %} Menus  {% endcomment %}
          <template
            x-data="{ isSmallScreen: window.outerWidth <= 1023 }"
            x-init="
              window.addEventListener('resize', () => {
                isSmallScreen = window.outerWidth <= 1023;
              });
            "
            x-if="isSmallScreen">
            <div class="footer__menus">
              {% for menu in menus %}
                {%- capture accordion_content -%}
                  {% if menu.settings.menu != blank %}
                    <ul class="footer__menu-list">
                      {% for link in menu.settings.menu.links %}
                        <li>
                          <a href="{{ link.url }}"
                            aria-label="{{ link.title }}"
                            title="{{ link.title }}">
                            <span>{{ link.title }}</span>
                          </a>
                        </li>
                      {% endfor %}
                      {% if menu.settings.show_accessibe_trigger %}
                        <li>
                          <a href="#" data-acsb-custom-trigger="true"
                            title="Accessibility"
                            aria-label="Accessibility">
                            Accessibility
                          </a>
                        </li>
                      {% endif %}
                    </ul>
                  {% endif %}
                {%- endcapture -%}
                {% render 'mfr-component__accordion',
                  block_id: menu.id,
                  class: "footer__menu",
                  trigger_class: "footer__menu-label",
                  trigger_label: menu.settings.heading,
                  content_class: "",
                  content: accordion_content %}
              {% endfor %}
            </div>
          </template>
          <template
            x-data="{ isSmallScreen: window.outerWidth <= 1023 }"
            x-init="
              window.addEventListener('resize', () => {
                isSmallScreen = window.outerWidth <= 1023;
              });
            "
            x-if="!isSmallScreen">
            <div class="footer__menus">
              {% for menu in menus %}
                <div class="footer__menu">
                  <p class="footer__menu-label">
                    {{ menu.settings.heading }}
                  </p>
                  <ul class="footer__menu-list">
                    {% for link in menu.settings.menu.links %}
                      <li>
                        <a href="{{ link.url }}"
                          aria-label="{{ link.title }}"
                          title="{{ link.title }}">
                          <span>{{ link.title }}</span>
                        </a>
                      </li>
                    {% endfor %}
                    {% if menu.settings.show_accessibe_trigger %}
                      <li>
                        <a href="#" data-acsb-custom-trigger="true"
                          title="Accessibility"
                          aria-label="Accessibility">
                          Accessibility
                        </a>
                      </li>
                    {% endif %}
                  </ul>
                </div>
              {% endfor %}
            </div>
          </template>

          {% comment %} Footer Socket  {% endcomment %}
          {% if socket != blank %}
            {% assign logo = socket.settings.logo %}

            <div class="footer__socket">
              {% if logo != blank %}
                <div class="footer__socket-logo" data-inview>
                  {% render 'component__lazyload-image',
                    image: logo,
                    height: "200",
                    alt: "Big Potato Games logo",
                    width: "500" %}
                </div>
              {% endif %}

              <div class="footer__socket-center">
                {% if social_links != blank %}
                  {% render 'footer__social-links' %}
                {% endif %}

                <div class="footer__socket-right">
                  {% if social_links.settings.caption != blank %}
                    <p class="footer__socket-caption">{{- social_links.settings.caption -}}</p>
                  {% endif %}
                </div>
              </div>
            </div>
          {% endif %}

          <p class="footer__copyright" data-inview>
            ©Big Potato 2025  — Site by
            <a href="https://manufactur.co" target="_blank" aria-label="Manufactur" title="Manufactur">Manufactur</a>
          </p>

          <div class="section-divider__top">
            {% render 'assets__top-divider-1', color: "#ef3373" %}
          </div>
        </div>
      {% endif %}

    </div>
  </div>
{% else %}
  <style>
    #shopify-section-{{- section.id -}} {
      visibility: hidden;
      display: none;
    }
  </style>
{% endif %}

{% if embed == blank or template == 'index' %}
  {%- render 'component__section-dividers', is_video_background: true -%}
{% endif %}

{% schema %}
{
  "name": "Footer",
  "class": "footer__main",
  "enabled_on": {
    "groups": ["footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Color Schemes Settings"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "default": "scheme_1",
      "label": "Color Scheme",
      "info": "This will be the color scheme of the footer initially."
    },
    {
      "type": "header",
      "content": "Visibility Settings"
    },
    {
      "type": "textarea",
      "id": "appear_on",
      "label": "Appear Only On:",
      "info": "Separated by newline. Insert template.suffix. Example: product or product.bundles"
    },
    {
      "type": "header",
      "content": "Divider Settings"
    },
    {
      "type": "select",
      "id": "section_divider_top",
      "label": "Section Divider - Top",
      "options": [
        {
          "value": "",
          "label": "None"
        },
        {
          "value": "divider_1",
          "label": "Custom Divider 1"
        },
        {
          "value": "line",
          "label": "Line"
        },
        {
          "value": "rounded",
          "label": "Rounded"
        },
        {
          "value": "scale",
          "label": "Scale"
        }
      ],
      "default": ""
    }
  ],

  "blocks": [
    {
      "type": "embed",
      "name": "Embed",
      "limit": 3,
      "settings": [
        {
          "type": "text",
          "label": "Domain",
          "id": "domain"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Lorem, ipsum dolor."
        },
        {
          "type": "textarea",
          "id": "caption",
          "label": "Caption",
          "default": "Lorem ipsum dolor sit amet consectetur adipisicing elit"
        },
        {
          "type": "richtext",
          "id": "description",
          "label": "Description",
          "default": "<p>Lorem ipsum dolor sit amet consectetur adipisicing elit</p>"
        },
        {
          "type": "textarea",
          "id": "embed_code",
          "label": "Embed Code"
        }
      ]
    },
    {
      "type": "menu",
      "name": "Menu",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Heading"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu"
        },
        {
          "type": "checkbox",
          "id": "show_accessibe_trigger",
          "label": "Show Accessibe Trigger",
          "default": false
        },
      ]
    },
    {
      "type": "big_menu",
      "name": "Big Menu",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Lorem ipsum"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu"
        }
      ]
    },
    {
      "type": "socket",
      "name": "Footer Socket",
      "limit": 1,
      "settings": [
        {
          "type": "image_picker",
          "id": "logo",
          "label": "Logo"
        }
      ]
    },
    {
      "type": "social_links",
      "name": "Social Links",
      "limit": 1,
      "settings": [
        {
          "type": "header",
          "content": "Social Links"
        },
        {
          "type": "text",
          "id": "caption",
          "label": "Caption"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Footer"
    }
  ]
}
{% endschema %}
