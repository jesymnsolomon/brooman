{% capture comment_form %}
  <div class="article-comments__form"
    data-mfr-comment-form>
      {% form 'new_comment', article %}
          <input type="hidden" name="comment[body]">

          <div class="article-comments__form-stars">
              <div class="article-comments__form-stars-inner">
                  {% for i in (1..5) %}
                      <label>
                          <input type="radio" name="stars" value="{{ i }}" {% if forloop.last %}checked{% endif %} />
                          {% for star in (1..i) %}
                              <span class="icon">★</span>
                          {% endfor %}
                      </label>
                  {% endfor %}
              </div>
          </div>
          <div class="article-comments__form-input">
              <input type="text" name="comment[author]" placeholder="Your name">
          </div>
          <div class="article-comments__form-input">
              <input type="email" name="comment[email]" placeholder="Your email">
          </div>
          <div class="article-comments__form-input">
              <input type="text" name="title" placeholder="Your Comment Title">
          </div>
          <div class="article-comments__form-input">
              <textarea name="content" placeholder="Your Comment Description"></textarea>
          </div>
          
          <button class="button primary">Submit</button>
      {% endform %}
  </div>
{% endcapture %}

{% capture comment_list %}
  {% if article.comments_count >= 1 %}
    <div class="article-comments__list" data-load-more="3">
      {% for comment in article.comments %}
        {% assign name = comment.author %}
        {% assign body =  comment.content | strip_html | split: "|" %}
        {% assign star_count = body[0] %}
        {% assign title = body[1] %}
        {% assign content = body[2] %}
        {% assign date = comment.created_at | date: "%m/%d/%Y" %}
        <div class="article-comments__entry" data-load-more-entry>
          <div class="article-comments__entry-header">
            <div class="article-comments__entry-avatar">
              {% assign first = name | split: " " | first | first %}
              {% assign last = name | split: " " | last | first %}

              {{ first }}{{ last }}
            </div>
            <div class="article-comments__entry-name">
              <span>{{ name }}</span>
              <span>
                  {% for star in (1..star_count) %}
                      <span class="icon">★</span>
                  {% endfor %}
              </span>
            </div>
            <div class="article-comments__entry-date">
              {{ date }}
            </div>
          </div>

          <div class="article-comments__entry-body">
            {% if title != blank %}
              <div class="article-comments__entry-title">
                {{ title }}
              </div>
          {% endif %}
            {% if content != blank %}
              <div class="article-comments__entry-content">
                {{ content }}
              </div>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>
  {% endif %}
{% endcapture %}
<div class="article-comments"
  x-data='MFRCommentForm'>
  {% if article.comments_enabled? %}
    {{ comment_list }}
    {{ comment_form }}
  {%- elsif request.design_mode -%}
    <form action="">
        <input type="hidden" name="comment[body]">

        <div class="article-comments__form-stars">
            <div class="article-comments__form-stars-inner">
                {% for i in (1..5) %}
                    <label>
                        <input type="radio" name="stars" value="{{ i }}" {% if forloop.last %}checked{% endif %} />
                        {% for star in (1..i) %}
                            <span class="icon">★</span>
                        {% endfor %}
                    </label>
                {% endfor %}
            </div>
        </div>
        <div class="article-comments__form-input">
            <input type="text" name="comment[author]" placeholder="Your name">
        </div>
        <div class="article-comments__form-input">
            <input type="email" name="comment[email]" placeholder="Your email">
        </div>
        <div class="article-comments__form-input">
            <input type="text" name="title" placeholder="Your Comment Title">
        </div>
        <div class="article-comments__form-input">
            <textarea name="content" placeholder="Your Comment Description"></textarea>
        </div>
        
        <button class="button primary">Submit</button>
    </form>
    <div class="article-comments__list" data-load-more="3">
      <div class="article-comments__entry" data-load-more-entry>
        <div class="article-comments__entry-header">
          <div class="article-comments__entry-avatar">
            JD
          </div>
          <div class="article-comments__entry-name">
            <span>John Doe</span>
            <span>
              {% for star in (1..5) %}
                <span class="icon">★</span>
              {% endfor %}
            </span>
          </div>
          <div class="article-comments__entry-date">
            1/1/2000
          </div>
        </div>

        <div class="article-comments__entry-body">
          <div class="article-comments__entry-title">
            Lorem ipsum dolor sit amet.
          </div>
          <div class="article-comments__entry-content">
            Lorem ipsum dolor sit amet, consectetur adipisicing elit. Excepturi, quas dolorum placeat impedit ratione aut?
          </div>
        </div>
      </div>
    </div>
  {% endif %}
</div>
{% render 'script__section', file: "MFRCommentForm.js" %}

{% schema %}
  {
    "name": "Comment Form",
    "class": "cell small-12 article-comments__wrapper"
  }
{% endschema %}