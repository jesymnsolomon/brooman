{%- if block.settings.text != blank -%}
  <p class="mfr-list__item-inner {{ block.settings.text_style }}">
    {{ block.settings.text }}
  </p>
{%- endif -%}
{%- schema -%}
{
  "name": "List Item",
  "class": "mfr-list__item",
  "tag": "li",
  "settings": [
    {
      "type": "text",
      "id": "text",
      "label": "Text",
      "default": "Lorem ipsum, dolor sit amet consectetur adipisicing elit"
    },
    {
      "type":"select",
      "id":"text_style",
      "options":[
        { "value":"", "label":"Default" },
        { "value":"xsmall", "label":"xSmall" },
        { "value":"small", "label":"Small" },
        { "value":"regular", "label":"Regular" },
        { "value":"large", "label":"Large" },
        { "value":"xlarge", "label":"xLarge" }
      ],
      "label":"Style",
      "default":"regular"
    }
  ],
  "presets": [
    {
      "name": "List Item"
    }
  ]
}
{%- endschema -%}
