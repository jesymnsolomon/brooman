<div class="form-name">
  <label for="contactFormName" class="sr-only">Name</label>
  <input type="text" id="contactFormName" name="contact[name]" placeholder="Name" autocapitalize="words" required value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}">
</div>

<div class="form-email">
  <label for="contactFormEmail" class="sr-only">Email</label>
  <input type="email" id="contactFormEmail" name="contact[email]" placeholder="Email" autocorrect="off" autocapitalize="off" required value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}">
</div>
{% schema %}
  {
    "name": "Email & Name",
    "class": "form-email-name",
    "presets": [
      {
        "name": "Email & Name"
      }
    ]
  }
{% endschema %}
