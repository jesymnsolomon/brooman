{% if block.settings.mobile_alignment == "left" %}
  {%- assign justify_content = "flex-start" -%}
  {%- assign text_align = "left" -%}
{%- elsif block.settings.mobile_alignment == "center" -%}
  {%- assign justify_content = "center" -%}
  {%- assign text_align = "center" -%}
{%- elsif block.settings.mobile_alignment == "right" -%}
  {%- assign justify_content = "flex-end" -%}
  {%- assign text_align = "right" -%}
{% endif %}

{% if block.settings.desktop_alignment == "left" %}
  {%- assign justify_content_desktop = "flex-start" -%}
  {%- assign text_align_desktop = "left" -%}
{%- elsif block.settings.desktop_alignment == "center" -%}
  {%- assign justify_content_desktop = "center" -%}
  {%- assign text_align_desktop = "center" -%}
{%- elsif block.settings.desktop_alignment == "right" -%}
  {%- assign justify_content_desktop = "flex-end" -%}
  {%- assign text_align_desktop = "right" -%}
{%- endif -%}

<style>
  {%- if block.settings.desktop_alignment != blank -%}
    @media (min-width: 1024px) {
      #shopify-block-{{ block.id }}  .column {
        justify-content: {{ justify_content_desktop }};
        text-align: {{ text_align_desktop }};
      }
    }
  {%- endif -%}
  {%- if block.settings.mobile_alignment != blank -%}
    @media (max-width: 1023px) {
      #shopify-block-{{ block.id }} .column {
        justify-content: {{ justify_content }};
        text-align: {{ text_align }};
      }
    }
  {%- endif -%}
</style>

<div class="column"
          data-stagger-inview=".section-icon__wrapper, .section-content__small-text, .section-content__text, .section-content__button, .accordion__wrapper, .mfr-list__wrapper li">
    {%- content_for "block", type: "_section-content", id: "section-content" -%}
</div>

{% schema %}
  {
    "name": "Column",
    "class": "cell small-12 large-6 section-content mfr-column",
    "settings": [
    {
      "type": "header",
      "content": "Alignment Settings"
    },
    {
      "type": "select",
      "id": "mobile_alignment",
      "label": "Content Alignment - Mobile",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "desktop_alignment",
      "label": "Content Alignment - Desktop",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    ],
    "presets": [
      {
        "name": "Column"
      }
    ]
  }
{% endschema %}