{% comment %}
    Attributes

    - text
    - color
    - bold_color
    - text_style
    - font_family
    - shopify_attributes
{% endcomment %}

{% assign color = block.settings.color %}
{% assign max_width = block.settings.max_width %}
{% assign text = block.settings.text %}
{% assign text_style = block.settings.text_style %}
{% assign highlight_color = block.settings.highlight_color %}
{% assign underline_color = block.settings.underline_color %}
{% assign disable_animation = block.settings.disable_animation %}
{% assign custom_font = block.settings.font_family %}
{% assign device_visibility = block.settings.visibility %}
{% assign max_width_mobile = block.settings.max_width_mobile %}
{% assign max_width_desktop = block.settings.max_width_desktop %}
{% assign margin_top = block.settings.margin_top %}
{% assign margin_bottom = block.settings.margin_bottom %}

{% if color != "" and color != "rgba(0,0,0,0)" %}
  {% assign has_custom_color = "has-custom-color" %}
  {% assign color_style = "color: " | append: color | append: ";" %}
{% else %}
  {% assign has_custom_color = "" %}
  {% assign color_style = "" %}
{% endif %}

{% if underline_color != "" and underline_color != "rgba(0,0,0,0)" %}
  {% assign has_underline_class = "has-underline" %}
{% else %}
  {% assign has_underline_class = "" %}
{% endif %}

<style>
  #shopify-block-{{ block.id }} {
    --highlight-color: {{ highlight_color }};
    {% if max_width_mobile != blank and max_width_mobile != 0 %}
      --max-width-mobile: {{ max_width_mobile }}px;
    {% endif %}
    {% if max_width_desktop != blank and max_width_desktop != 0 %}
      --max-width-desktop: {{ max_width_desktop }}px;
    {% endif %}
    {% if margin_top != blank %}
      --margin-top: {{ margin_top }}px;
    {% endif %}
    {% if margin_bottom != blank %}
      --margin-bottom: {{ margin_bottom }}px;
    {% endif %}
    {% if highlight_color != "" and highlight_color != "rgba(0,0,0,0)" %}
      --underline-color: {{ underline_color }};
    {% endif %}
  }
</style>
{%- if text != blank -%}
  <div
    class="section-text {{ text_style }} {{ has_custom_color }} {% if disable_animation %}disable-inview{% endif %} {{ has_underline_class }} {{ custom_font }} {{ device_visibility }}"
    data-inview
    data-stagger-inview="> *"
    {{ block.shopify_attributes }}
    style="{{ color_style }}">
    {% render 'shortcode-renderer', text: text %}
  </div>
{%- endif -%}

{% schema %}
  {
    "name": "Section Text",
    "class": "section-text__wrapper",
    "settings": [
      {
        "type": "richtext",
        "id": "text",
        "default": "<p>Lorem ipsum dolor sit amet, consectetur adipiscing elit. Vestibulum vel metus auctor.</p>",
        "label": "Text"
      },
      {
        "type": "select",
        "id": "visibility",
        "label": "Visibility",
        "options": [
          { "value": "", "label": "Both"},
          { "value": "desktop", "label": "On Desktop"},
          { "value": "mobile", "label": "On Mobile"}
        ],
        "default" : ""
      },
      {
        "type": "checkbox",
        "id": "disable_animation",
        "label": "Disable Animation",
        "default": false
      },
      {
        "type":"select",
        "id":"text_style",
        "options":[
          { "value":"", "label":"Default" },
          { "value":"xsmall", "label":"xSmall" },
          { "value":"small", "label":"Small" },
          { "value":"regular", "label":"Regular" },
          { "value":"large", "label":"Large" },
          { "value":"xlarge", "label":"xLarge" }
        ],
        "label":"Style",
        "default":"regular"
      },
      {
        "type": "select",
        "id": "font_family",
        "label": "Custom Font Family",
        "options": [
          {
            "value": "",
            "label": "Use Theme Settings"
          },
          {
            "value": "custom-font-name-1",
            "label": "Custom Font 1"
          },
          {
            "value": "custom-font-name-2",
            "label": "Custom Font 2"
          },
          {
            "value": "custom-font-name-3",
            "label": "Custom Font 3"
          },
          {
            "value": "custom-font-name-4",
            "label": "Custom Font 4"
          }
        ],
        "default": ""
      },
      {
        "type": "header",
        "content": "Color Settings"
      },
      {
        "type": "color",
        "id": "color",
        "label": "Text Color",
        "info": "Leave it blank to use system settings."
      },
      {
        "type": "color",
        "id": "highlight_color",
        "label": "Highlight Color",
        "info": "This will change the color of all bolded text."
      },
      {
        "type": "color",
        "id": "underline_color",
        "label": "Underline Color",
        "info": "This will add underline (with the set color) to all bolded text."
      },

      {
        "type": "header",
        "content": "Width Settings"
      },
      {
        "type": "number",
        "id": "max_width_mobile",
        "label": "Max Width - Mobile",
        "default": 0,
        "info": "in pixels"
      },
      {
        "type": "number",
        "id": "max_width_desktop",
        "label": "Max Width - Desktop",
        "default": 0,
        "info": "in pixels"
      },
       {
        "type": "header",
        "content": "Margin Settings"
      },
      {
        "type": "number",
        "id": "margin_top",
        "label": "Margin Top",
        "info": "Margin top in pixels"
      },
      {
        "type": "number",
        "id": "margin_bottom",
        "label": "Margin Bottom",
        "info": "Margin bottom in pixels"
      }
    ],
    "presets": [
      {
        "name": "Section Text"
      }
    ]
  }
{% endschema %}
