{%- if settings.custom_font_1_url != blank -%}
  {% assign urls = settings.custom_font_1_url | strip | split: ',' %}
  {% for url in urls %}
    <link rel="preload" href="{{ url }}" as="font" type="font/{{ url | split: '.' | last | split: '?' | first }}" crossorigin>
  {% endfor %}
{%- endif -%}

