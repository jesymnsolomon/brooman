      --button-font-family: '{{ settings.button_font_family_custom_name }}', {{ settings.button_font_family.family }}, {{ settings.button_font_family.fallback_families }};
    {% else %}
      --button-font-family: {{ settings.button_font_family.family }}, {{ settings.button_font_family.fallback_families }};
    {% endif %}
    --button-font-case: {% if settings.button_font_case %}uppercase{% else %}none{% endif %};
    --button-font-weight: {{ settings.button_font_weight }};
    --button-font-size-mobile: {{ settings.button_font_size_mobile }}px;
    --button-line-height-mobile: {{ settings.button_line_height_mobile }}px;
    --button-letter-spacing-mobile: {{ settings.button_font_spacing_mobile }}px;
    --button-font-size: {{ settings.button_font_size }}px;
    --button-line-height: {{ settings.button_line_height }}px;
    --button-letter-spacing: {{ settings.button_font_spacing }}px;

    --button-border-width: {{ settings.button_border_width }}px;
    --button-border-radius: {{ settings.button_border_radius }}px;


    --primary-button-bg-color: {{ settings.primary_button_bg }};
    --primary-button-bg-gradient: {{ settings.primary_button_bg_gradient }};
    --primary-button-text-color: {{ settings.primary_button_text }};
    --primary-button-border-color: {{ settings.primary_border_color }};
    --primary-button-hover-bg-color: {{ settings.primary_button_hover_bg }};
    --primary-button-hover-bg-gradient: {{ settings.primary_button_hover_bg_gradient }};
    --primary-button-hover-text-color: {{ settings.primary_button_hover_text }};
    --primary-button-border-color-hover: {{ settings.primary_border_color_hover }};

    --secondary-button-bg-color: {{ settings.secondary_button_bg }};
    --secondary-button-text-color: {{ settings.secondary_button_text }};
    --secondary-button-border-color: {{ settings.secondary_border_color }};
    --secondary-button-hover-bg-color: {{ settings.secondary_button_hover_bg }};
    --secondary-button-hover-text-color: {{ settings.secondary_button_hover_text }};
    --secondary-button-border-color-hover: {{ settings.secondary_border_color_hover }};

    --tertiary-button-bg-color: {{ settings.tertiary_button_bg }};
    --tertiary-button-text-color: {{ settings.tertiary_button_text }};
    --tertiary-button-border-color: {{ settings.tertiary_border_color }};
    --tertiary-button-hover-bg-color: {{ settings.tertiary_button_hover_bg }};
    --tertiary-button-hover-text-color: {{ settings.tertiary_button_hover_text }};
    --tertiary-button-border-color-hover: {{ settings.tertiary_border_color_hover }};
  }


  {%- comment -%} --------------------------------------
  set css for bold and uppercase settings
  -------------------------------------- {%- endcomment -%}


  .menu a, .header-cta {
    {%- if settings.menu_font_weight -%}
      font-weight: 700 !important;
    {%- endif -%}
    {%- if settings.menu_font_case -%}
      text-transform: uppercase;
    {%- endif -%}
  }

  .button, button {
    {%- if settings.general_button_weight -%}
      font-weight: 800 !important;
    {%- else -%}
      font-weight: 400;
    {%- endif -%}
    {%- if settings.general_button_case -%}
      text-transform: uppercase;
    {%- endif -%}
  }


  #offCanvasCart .product__name {
    {%- if settings.cart_product_name_weight -%}
      font-weight: 700 !important;
    {%- endif -%}
    {%- if settings.cart_product_name_case -%}
      text-transform: uppercase;
    {%- endif -%}
  }


  {% endstyle %}
