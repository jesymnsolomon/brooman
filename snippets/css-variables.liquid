{% style %}

{%- comment -%}
--------------------------------------
output font-face for custom fonts if they exist
--------------------------------------
{%- endcomment -%}

{%- if settings.custom_font_1_url != blank -%}
  {% assign urls = settings.custom_font_1_url | strip | split: ',' %}
  {% assign font_weight = settings.custom_font_1_weight | strip | split: ',' %}
  {% for url in urls %}
    @font-face {
      font-family: '{{ settings.custom_font_1_name }}';
      src: url('{{ url }}') format('woff2');
      {% if font_weight[forloop.index0] contains "-" %}
        font-weight: {{ font_weight[forloop.index0] | split: "-" | first }};
      {% else %}
        font-weight: {{ font_weight[forloop.index0] }};
      {% endif %}
      font-style: normal;
      font-display: swap;
      {% if font_weight[forloop.index0] contains "-" %}
        font-style: {{ font_weight[forloop.index0] | split: "-" | last }};
      {% endif %}
    }
  {% endfor %}
{%- endif -%}

{%- if settings.custom_font_2_url != blank -%}
  {% assign urls = settings.custom_font_2_url | strip | split: ',' %}
  {% assign font_weight = settings.custom_font_2_weight | strip | split: ',' %}
