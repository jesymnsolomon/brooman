<script id="faq-schema" type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {%- for item in items -%}
      {
        "@type": "Question",
        "name": "{{- item.settings[question_var] -}}",
        "acceptedAnswer": {
        "@type": "Answer",
        "text": "<p>{{- item.settings[answer_var] | strip_html -}}</p>"
      }
    }{%- unless forloop.last -%},{%- endunless -%}
    {%- endfor -%}
  ]
}
</script>