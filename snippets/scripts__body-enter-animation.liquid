{% comment %} <script>
  // Select the body element and set its opacity to 0
  document.body.style.opacity = '0';

  // Add a load event listener to remove opacity
  {% comment %} window.addEventListener('load', function() {
    document.body.style.opacity = '1'; // Remove opacity after the page has fully loaded
  }); {% endcomment %}
</script> {% endcomment %}