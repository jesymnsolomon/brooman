<div class="cell card-grid-block card-slider" data-slider-id="team-grid-mobile-slider">
  <div class="card">
    {% if title != blank %}
    <div class="card-divider card-header">
        <h2 class="h4 text-center">{{ title }}</h2>
    </div>
    {% endif %}
    {% if image != blank %}
