      <img 
        loading="lazy" 
        src="{{ image | img_url: '600x600', crop: 'center' }}" 
        srcset="{{ image | img_url: '600x600', crop: 'center' }} 1x, {{ image | img_url: '600x600', scale: 2, crop: 'center' }} 2x" 
        alt="{{ image.alt }}">

